#!/bin/bash

# 변경 대상 계정명을 정의한다. (예시 abc)
TARGET_USER="abc"

# 변경할 신규 패스워드를 정의한다. (예시 001001)
NEW_PASSWORD="001001"

# 로그 파일 경로를 정의한다.
LOG_FILE="/var/log/password_change_${TARGET_USER}.log"

# 작업 시작 시간을 로그에 남긴다.
echo "===== START : $(date '+%F %T') =====" >> "${LOG_FILE}"

# 현재 실행 사용자를 로그에 남긴다.
echo "RUN AS : $(id -un)" >> "${LOG_FILE}"

# 대상 계정 존재 여부를 확인한다.
if id "${TARGET_USER}" >/dev/null 2>&1; then

    # 계정이 존재하면 패스워드 변경을 시도한다.
    echo "${TARGET_USER}:${NEW_PASSWORD}" | chpasswd

    # chpasswd 실행 결과를 확인한다.
    if [ $? -eq 0 ]; then
        # 성공 시 성공 로그를 남긴다.
        echo "RESULT : SUCCESS" >> "${LOG_FILE}"

        # 화면에도 성공 메시지를 출력한다.
        echo "SUCCESS : password changed for ${TARGET_USER}"
    else
        # 실패 시 실패 로그를 남긴다.
        echo "RESULT : FAIL - chpasswd error" >> "${LOG_FILE}"

        # 화면에도 실패 메시지를 출력한다.
        echo "FAIL : chpasswd failed for ${TARGET_USER}"

        # 실패 코드로 종료한다.
        exit 1
    fi

else
    # 계정이 없으면 skip 로그를 남긴다.
    echo "RESULT : SKIP - user not found" >> "${LOG_FILE}"

    # 화면에도 skip 메시지를 출력한다.
    echo "SKIP : user ${TARGET_USER} does not exist"

    # 계정 미존재는 운영상 실패로 볼 수도 있으므로 2로 종료한다.
    exit 2
fi

# 작업 종료 시간을 로그에 남긴다.
echo "===== END : $(date '+%F %T') =====" >> "${LOG_FILE}"
