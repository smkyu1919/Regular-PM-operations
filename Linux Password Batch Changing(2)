# root 계정에 적용할 신규 패스워드를 정의한다
ROOT_PASSWORD="001001"

# 패스워드를 변경할 운영 계정명을 정의한다
TARGET_USER="mgmt"

# 운영 계정에 적용할 신규 패스워드를 정의한다
USER_PASSWORD="001001"

# 현재 서버의 hostname을 변수에 저장한다
HOST_NAME="$(hostname)"

# root 계정 패스워드를 변경한다
echo "root:${ROOT_PASSWORD}" | chpasswd

# 운영 계정이 존재하면 패스워드를 변경한다
if id "${TARGET_USER}" >/dev/null 2>&1; then
  echo "${TARGET_USER}:${USER_PASSWORD}" | chpasswd
fi

# root 계정의 chage 결과를 영문 고정으로 조회한다
ROOT_CHAGE_OUTPUT="$(LC_ALL=C chage -l root 2>/dev/null)"

# root 계정의 만료일자를 1차로 정확 키워드로 추출한다
ROOT_EXPIRE="$(printf '%s\n' "${ROOT_CHAGE_OUTPUT}" | awk -F': ' '/^Password expires/ {print $2; exit}')"

# root 계정의 만료일자가 비어 있으면 2차로 expire 포함 문자열 중 password 관련 값을 추출한다
if [ -z "${ROOT_EXPIRE}" ]; then
  ROOT_EXPIRE="$(printf '%s\n' "${ROOT_CHAGE_OUTPUT}" | awk -F': ' 'BEGIN{IGNORECASE=1} /password/ && /expire/ {print $2; exit}')"
fi

# root 계정의 만료일자가 끝까지 비어 있으면 UNKNOWN으로 표시한다
if [ -z "${ROOT_EXPIRE}" ]; then
  ROOT_EXPIRE="UNKNOWN"
fi

# 운영 계정 존재 여부를 확인한다
if id "${TARGET_USER}" >/dev/null 2>&1; then

  # 운영 계정의 chage 결과를 영문 고정으로 조회한다
  USER_CHAGE_OUTPUT="$(LC_ALL=C chage -l "${TARGET_USER}" 2>/dev/null)"

  # 운영 계정의 만료일자를 1차로 정확 키워드로 추출한다
  USER_EXPIRE="$(printf '%s\n' "${USER_CHAGE_OUTPUT}" | awk -F': ' '/^Password expires/ {print $2; exit}')"

  # 운영 계정의 만료일자가 비어 있으면 2차로 expire 포함 문자열 중 password 관련 값을 추출한다
  if [ -z "${USER_EXPIRE}" ]; then
    USER_EXPIRE="$(printf '%s\n' "${USER_CHAGE_OUTPUT}" | awk -F': ' 'BEGIN{IGNORECASE=1} /password/ && /expire/ {print $2; exit}')"
  fi

  # 운영 계정은 존재하지만 만료일 조회값이 비어 있으면 UNKNOWN으로 표시한다
  if [ -z "${USER_EXPIRE}" ]; then
    USER_EXPIRE="UNKNOWN"
  fi

else

  # 계정이 없으면 NOT_FOUND로 표시한다
  USER_EXPIRE="NOT_FOUND"

fi

# 현재 서버 hostname을 출력한다
echo "HOST: ${HOST_NAME}"

# 패스워드 변경 대상 계정을 출력한다
echo "SUCCESS: root, ${TARGET_USER}"

# root 및 운영 계정의 패스워드 만료일을 출력한다
echo "Password expires: root=${ROOT_EXPIRE}, ${TARGET_USER}=${USER_EXPIRE}"
