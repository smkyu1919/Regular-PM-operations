# root 계정에 적용할 신규 패스워드를 정의한다
ROOT_PASSWORD="001001"

# 패스워드를 변경할 운영 계정명을 정의한다
TARGET_USER="sysmgmt"

# 운영 계정에 적용할 신규 패스워드를 정의한다
USER_PASSWORD="001001"

# 현재 서버의 hostname을 변수에 저장한다
HOST_NAME="$(hostname)"

# root 계정 패스워드를 변경한다
echo "root:${ROOT_PASSWORD}" | chpasswd

# 운영 계정이 존재하는지 확인한다
if id "${TARGET_USER}" >/dev/null 2>&1; then

  # 운영 계정 패스워드를 변경한다
  echo "${TARGET_USER}:${USER_PASSWORD}" | chpasswd

fi

# root 계정 패스워드 만료일을 조회한다
ROOT_EXPIRE=$(chage -l root 2>/dev/null | grep "Password expires" | awk -F': ' '{print $2}')

# 운영 계정 존재 여부를 확인한다
if id "${TARGET_USER}" >/dev/null 2>&1; then

  # 운영 계정 패스워드 만료일을 조회한다
  USER_EXPIRE=$(chage -l "${TARGET_USER}" 2>/dev/null | grep "Password expires" | awk -F': ' '{print $2}')

else

  # 계정이 없는 서버일 경우 N/A로 표시한다
  USER_EXPIRE="N/A"

fi

# 서버 hostname 출력
echo "HOST: ${HOST_NAME}"

# 패스워드 변경 대상 계정 출력
echo "SUCCESS: root, ${TARGET_USER}"

# 패스워드 만료일 출력
echo "Password expires: root=${ROOT_EXPIRE}, ${TARGET_USER}=${USER_EXPIRE}"
