ROOT_PASSWORD="Root패스워드"; \  # root 계정에 적용할 신규 패스워드를 정의한다
TARGET_USER="운영계졍명"; \  # 변경 대상 운영 계정명을 정의한다
USER_PASSWORD="운영계정 패스워드"; \  # 운영 계정에 적용할 신규 패스워드를 정의한다
HOST_NAME="$(hostname)"; \  # 현재 서버의 hostname을 변수에 저장한다
echo "root:${ROOT_PASSWORD}" | chpasswd; \  # root 계정의 패스워드를 변경한다
if id "${TARGET_USER}" >/dev/null 2>&1; then \  # 운영 계정 존재 여부를 확인한다
  echo "${TARGET_USER}:${USER_PASSWORD}" | chpasswd; \  # 운영 계정 패스워드를 변경한다
fi; \  # 운영 계정 존재 조건문 종료
ROOT_EXPIRE=$(chage -l root 2>/dev/null | grep "Password expires" | awk -F': ' '{print $2}'); \  # root 계정의 패스워드 만료일을 조회한다
if id "${TARGET_USER}" >/dev/null 2>&1; then \  # 운영 계정 존재 여부를 다시 확인한다
  USER_EXPIRE=$(chage -l "${TARGET_USER}" 2>/dev/null | grep "Password expires" | awk -F': ' '{print $2}'); \  # 운영 계정 패스워드 만료일을 조회한다
else \  # 운영 계정이 존재하지 않는 경우
  USER_EXPIRE="N/A"; \  # 운영 계정이 없을 경우 만료일을 N/A로 표시한다
fi; \  # 운영 계정 조회 조건문 종료
echo "HOST: ${HOST_NAME}"; \  # 현재 서버 hostname을 출력한다
echo "SUCCESS: root, ${TARGET_USER}"; \  # 패스워드 변경 완료 메시지를 출력한다
echo "Password expires: root=${ROOT_EXPIRE}, ${TARGET_USER}=${USER_EXPIRE}"  # root 및 운영 계정 패스워드 만료일을 출력한다
