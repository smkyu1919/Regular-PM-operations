echo "STEP=PRECHECK" && \
echo "HOST=$(hostname) | TIME=$(date '+%F %T %Z')" && \
echo "OS=$(cat /etc/os-release | egrep '^(NAME|VERSION|VERSION_ID)=' | tr '\n' ' ')" && \
echo "RUNNING_KERNEL=$(uname -r)" && \
echo "INSTALLED_KERNELS=$(rpm -qa | grep '^kernel' | sort -V | tail -n 5 | tr '\n' ' ')" && \
echo "STEP=REPO_PREPARE" && \
if grep -qiE '^NAME=.*CentOS Stream' /etc/os-release && grep -qE '^VERSION_ID="?8' /etc/os-release; then \
  echo "REPO_FIX=CentOSStream8_mirrorlist_to_vault" && \
  sudo sed -i \
    -e 's|^mirrorlist=|#mirrorlist=|g' \
    -e 's|^#baseurl=http://mirror.centos.org|baseurl=http://vault.centos.org|g' \
    /etc/yum.repos.d/CentOS-Stream-*.repo || true; \
  sudo yum clean all || true; \
  sudo yum makecache || true; \
else \
  echo "REPO_FIX=SKIP"; \
fi && \
echo "STEP=APPLY_SECURITY_UPDATE" && \
sudo yum -y update --security --exclude=kernel* --exclude=kernel-* 2>&1 | tee /tmp/yum_security_update.log; rc=${PIPESTATUS[0]} && \
if [ "$rc" -ne 0 ]; then \
  if grep -qiE 'Failed to download metadata for repo|Cannot prepare internal mirrorlist|Could not resolve host|Curl error \(6\)|Curl error \(7\)|Operation timed out|Timeout|No route to host|Could not connect' /tmp/yum_security_update.log; then \
    echo "RESULT=REPO_UNREACHABLE_OR_METADATA_FAILED rc=${rc}"; \
    echo "DETAIL=CHECK_DNS_ROUTE_NACL_SG_REPO_MIRRORLIST"; \
  else \
    echo "RESULT=YUM_FAILED rc=${rc}"; \
  fi; \
  exit "$rc"; \
fi && \
if grep -qiE 'Nothing to do|No packages marked for update|No security updates needed' /tmp/yum_security_update.log; then \
  echo "RESULT=NO_SECURITY_UPDATES"; \
else \
  echo "RESULT=SECURITY_UPDATES_APPLIED"; \
  echo "ACTION=REBOOT"; \
  sudo reboot; \
fi
